datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Registration {
  id                    Int      @id @default(autoincrement())
  name                  String
  email                 String
  phone                 String
  age                   String
  city                  String
  role                  String
  churchName            String
  denomination          String
  foodPreference        String
  accommodationRequired String
  expectations          String?
  agreeToTime           String
  createdAt             DateTime @default(now())
}
